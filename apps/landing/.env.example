# Convex connection (same deployment as web/dashboard)
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Better Auth (must match the Convex deployment's BETTER_AUTH_SECRET)
BETTER_AUTH_SECRET=

# Public site URL (http://localhost:3002 for local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Cross-subdomain cookies — leave empty in dev, set to .co-lab.no in prod
COOKIE_DOMAIN=
