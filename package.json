{
  "name": "evalion",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "turbo typecheck",
    "db:dev": "pnpm --filter @workspace/backend dev",
    "db:deploy": "pnpm --filter @workspace/backend deploy",
    "db:codegen": "pnpm --filter @workspace/backend codegen",
    "db:dashboard": "pnpm --filter @workspace/backend dashboard",
    "db:logs": "pnpm --filter @workspace/backend logs"
  },
  "devDependencies": {
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
