{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "@workspace/evalion/*": ["./src/*"],
      "@workspace/ui/*": ["../ui/src/*"],
      "@workspace/backend/*": ["../backend/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
